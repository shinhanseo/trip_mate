generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          BigInt    @id @default(autoincrement())
  naverUserId String    @unique @map("naver_user_id")
  status      String    @default("active") @db.VarChar(20)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  profile          UserProfile?
  loginExchanges   LoginExchange[]
  refreshTokens    RefreshToken[]
  socialAccounts   SocialAccount[]
  hostedMeetings   Meeting[]        @relation("MeetingHost")
  meetingMembers   MeetingMember[]
  chatRoomMembers  ChatRoomMember[]
  sentChatMessages ChatMessage[]    @relation("ChatMessageSender")
  submittedReports Report[]         @relation("ReportReporter")
  notifications    Notification[]

  @@map("users")
}

model UserProfile {
  userId          BigInt    @id @map("user_id")
  nickname        String?   @unique @db.VarChar(20)
  gender          String?   @db.VarChar(10)
  ageRange        String?   @map("age_range") @db.VarChar(20)
  favoriteTags    String[]  @default([]) @map("favorite_tags") @db.VarChar(255)
  bio             String?   @db.VarChar(80)
  profileImageUrl String?   @map("profile_image_url")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model LoginExchange {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  exchangeCodeHash String    @unique @map("exchange_code_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt           DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_exchanges")
}

model RefreshToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  tokenHash  String    @map("token_hash")
  deviceName String?   @map("device_name") @db.VarChar(100)
  deviceId   String?   @map("device_id") @db.VarChar(200)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model SocialAccount {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @map("user_id")
  provider       String
  providerUserId String    @map("provider_user_id")
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "social_accounts_provider_user_unique")
  @@unique([userId, provider], map: "social_accounts_user_provider_unique")
  @@map("social_accounts")
}

model Meeting {
  id              BigInt   @id @default(autoincrement())
  hostUserId      BigInt   @map("host_user_id")
  title           String   @db.VarChar(50)
  placeText       String   @map("place_text") @db.VarChar(100)
  placeLat        Decimal? @map("place_lat") @db.Decimal(10, 7)
  placeLng        Decimal? @map("place_lng") @db.Decimal(10, 7)
  regionPrimary   String   @map("region_primary") @db.VarChar(30)
  regionSecondary String?  @map("region_secondary") @db.VarChar(30)
  scheduledAt     DateTime @map("scheduled_at") @db.Timestamptz(6)
  maxMembers      Int      @map("max_members")
  gender          String   @db.VarChar(20)
  category        String   @db.VarChar(20)
  description     String
  status          String   @default("open") @db.VarChar(15)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  ageGroups       String[] @default(["any"]) @map("age_groups")
  address         String?  @default("") @db.VarChar(255)

  host     User            @relation("MeetingHost", fields: [hostUserId], references: [id], onDelete: Restrict)
  members  MeetingMember[]
  chatRoom ChatRoom?

  @@map("meetings")
}

model MeetingMember {
  id        BigInt    @id @default(autoincrement())
  meetingId BigInt    @map("meeting_id")
  userId    BigInt    @map("user_id")
  role      String    @default("member") @db.VarChar(20)
  status    String    @default("joined") @db.VarChar(20)
  joinedAt  DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt    DateTime? @map("left_at") @db.Timestamptz(6)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId], map: "meeting_members_meeting_id_user_id_key")
  @@map("meeting_members")
}

model ChatRoom {
  id        BigInt   @id @default(autoincrement())
  meetingId BigInt   @unique @map("meeting_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  meeting  Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  members  ChatRoomMember[]
  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatRoomMember {
  id                BigInt    @id @default(autoincrement())
  roomId            BigInt    @map("room_id")
  userId            BigInt    @map("user_id")
  joinedAt          DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  lastReadMessageId BigInt?   @map("last_read_message_id")
  lastReadAt        DateTime? @map("last_read_at") @db.Timestamptz(6)
  joinNoticeSent    Boolean   @default(false) @map("join_notice_sent")

  room            ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage ChatMessage? @relation("ChatRoomMemberLastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([roomId, userId], map: "chat_room_members_room_id_user_id_key")
  @@index([userId], map: "chat_room_members_user_id_idx")
  @@index([lastReadMessageId], map: "chat_room_members_last_read_message_id_idx")
  @@map("chat_room_members")
}

model ChatMessage {
  id        BigInt   @id @default(autoincrement())
  roomId    BigInt   @map("room_id")
  senderId  BigInt?  @map("sender_id")
  messageType String @default("text") @map("message_type")
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  room              ChatRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender            User?            @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  lastReadByMembers ChatRoomMember[] @relation("ChatRoomMemberLastReadMessage")

  @@index([roomId, createdAt], map: "chat_messages_room_id_created_at_idx")
  @@index([senderId], map: "chat_messages_sender_id_idx")
  @@map("chat_messages")
}

model Report {
  id         BigInt    @id @default(autoincrement())
  reporterId BigInt    @map("reporter_id")
  targetType String    @map("target_type") @db.VarChar(20)
  targetId   BigInt    @map("target_id")
  reason     String    @db.VarChar(50)
  detail     String?
  status     String    @default("pending") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  reporter User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId], map: "reports_reporter_id_idx")
  @@index([targetType, targetId], map: "reports_target_type_target_id_idx")
  @@index([status, createdAt], map: "reports_status_created_at_idx")
  @@map("reports")
}

model Notification {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  type       String    @db.VarChar(40)
  title      String    @db.VarChar(100)
  body       String
  targetType String?   @map("target_type") @db.VarChar(30)
  targetId   BigInt?   @map("target_id")
  readAt     DateTime? @map("read_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, createdAt], map: "notifications_user_deleted_created_idx")
  @@index([userId, readAt], map: "notifications_user_read_idx")
  @@map("notifications")
}
